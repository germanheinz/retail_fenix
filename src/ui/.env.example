# Backend service endpoints
RETAIL_UI_ENDPOINTS_CATALOG=http://localhost:8081
RETAIL_UI_ENDPOINTS_CARTS=http://localhost:8082
RETAIL_UI_ENDPOINTS_CHECKOUT=http://localhost:8085
RETAIL_UI_ENDPOINTS_ORDERS=http://localhost:8083

# Theme: default | green | orange | teal
RETAIL_UI_THEME=default

# App version (shown in navbar)
RETAIL_UI_VERSION=v1.0.0

# Chat configuration
RETAIL_UI_CHAT_ENABLED=false
RETAIL_UI_CHAT_PROVIDER=mock
RETAIL_UI_CHAT_MODEL=
RETAIL_UI_CHAT_TEMPERATURE=0.6
RETAIL_UI_CHAT_MAX_TOKENS=300
RETAIL_UI_CHAT_PROMPT=

# OpenAI (when provider=openai)
OPENAI_API_KEY=
OPENAI_BASE_URL=http://localhost:8000

# AWS Bedrock (when provider=bedrock)
AWS_REGION=us-east-1
